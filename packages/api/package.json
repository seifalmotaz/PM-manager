{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "bun --env-file=.env --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun --env-file=../../.env test"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.3.0",
    "@trpc/server": "^11.0.0",
    "@workos-inc/node": "^7.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}