{
    "$schema": "https://opencode.ai/config.json",
    "lsp": {
        "typescript": {
            "command": [
                "npx",
                "-y",
                "typescript-language-server",
                "--stdio"
            ]
        },
    },
    "mcp": {
        "postgres": {
            "enabled": true,
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-postgres",
                "postgresql://postgres:password@localhost:5432/saha"
            ]
        }
    }
}